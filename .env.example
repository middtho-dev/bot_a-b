BOT_TOKEN=your_bot_token
TIMEZONE=Asia/Dubai

# comma-separated user IDs allowed to run owner commands
OWNER_IDS=123456789

# dedicated admin chat for reports/alerts
ADMIN_CHAT_ID=-1000000000001

# common chat for check-in / eod prompts
GENERAL_CHAT_ID=-1000000000002

# specific chats for week 3 forms
SALES_CHAT_ID=-1000000000003
LOGISTICS_CHAT_ID=-1000000000004

# all work chats (7 existing chats)
WORK_CHAT_IDS=-1001111111111,-1002222222222,-1003333333333,-1004444444444,-1005555555555,-1006666666666,-1007777777777

# schedule (HH:MM)
REPORT_TIME=19:00
CHECKIN_TIME=10:00
EOD_TIME=22:00

# inactivity control (week 4)
WORK_START=09:00
WORK_END=22:00
INACTIVITY_MINUTES=60

# JSON array with employees
EMPLOYEES_JSON=[{"user_id":123456789,"username":"owner","full_name":"Owner","role":"general"}]

DATABASE_PATH=bot_data.sqlite3
