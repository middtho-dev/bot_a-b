BOT_TOKEN=your_bot_token
TIMEZONE=Asia/Dubai

# comma-separated user IDs allowed to run owner commands
OWNER_IDS=123456789

# Optional bootstrap values (recommended to configure from /admin menu in bot)
# ADMIN_CHAT_ID=-1000000000001
# GENERAL_CHAT_ID=-1000000000002
# SALES_CHAT_ID=-1000000000003
# LOGISTICS_CHAT_ID=-1000000000004
# WORK_CHAT_IDS=-1001111111111,-1002222222222

# Optional defaults (also configurable via /admin)
# REPORT_TIME=19:00
# CHECKIN_TIME=10:00
# EOD_TIME=22:00
# WORK_START=09:00
# WORK_END=22:00
# INACTIVITY_MINUTES=60

# Optional bootstrap employees JSON (you can add employees from /admin)
EMPLOYEES_JSON=[]

DATABASE_PATH=bot_data.sqlite3
