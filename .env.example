BOT_TOKEN=your_bot_token
TIMEZONE=Europe/Dubai

# comma-separated user IDs allowed to run owner commands
OWNER_IDS=123456789

# chat where bot sends daily/weekly reports
ADMIN_CHAT_ID=-1000000000001

# comma-separated existing work chat IDs (7 chats from ТЗ)
WORK_CHAT_IDS=-1001111111111,-1002222222222

# HH:MM
REPORT_TIME=19:00

# JSON array with employees allowed for analytics
EMPLOYEES_JSON=[{"user_id":123456789,"username":"owner","full_name":"Owner","role":"general"}]

# sqlite file path
DATABASE_PATH=bot_data.sqlite3
